<Window x:Class="TrikiReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="TrikiReader 3D - v1.0" Height="600" Width="900"
        Closing="Window_Closing">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10">
            <Button x:Name="BtnConnect" Content="Połącz z Triki" Height="40" Click="BtnConnect_Click" Margin="0,0,0,10" FontSize="16" FontWeight="Bold"/>
            <TextBlock Text="Orientacja 3D:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbOrientationMode" SelectedIndex="0" Height="28" Margin="0,0,0,10">
                <ComboBoxItem Content="Madgwick"/>
                <ComboBoxItem Content="Żappka-like tilt"/>
            </ComboBox>
            <TextBlock x:Name="TxtStatus" Text="Rozłączony" FontWeight="Bold" Margin="0,0,0,20" FontSize="14" Foreground="DarkGray"/>
            <TextBlock Text="Orientacja:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock x:Name="TxtAngles" Text="Pitch: --  Roll: --  Yaw: --" Margin="0,0,0,10" FontFamily="Consolas" FontSize="11"/>
            <Button x:Name="BtnResetOrientation" Content="Wyzeruj orientację" Height="28" Click="BtnResetOrientation_Click" Margin="0,0,0,10"/>
            <TextBlock Text="IMU:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock x:Name="TxtImu" Text="Gyro: --&#10;Accel: --" Margin="0,0,0,10" FontFamily="Consolas" FontSize="11"/>
            <TextBlock Text="Diagnostyka:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock x:Name="TxtDiagnostics" Text="Raw: --&#10;Hz: --&#10;Parser: --" Margin="0,0,0,10" FontFamily="Consolas" FontSize="11"/>
            <TextBlock Text="Log zdarzeń:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ScrollViewer Height="210" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="TxtLog" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"/>
            </ScrollViewer>
        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 3D Viewport -->
            <Border Grid.Row="0" Margin="10" BorderBrush="LightGray" BorderThickness="1">
                <Grid>
                    <Viewport3D ClipToBounds="True">
                        <Viewport3D.Camera>
                            <PerspectiveCamera Position="0,-5,0" LookDirection="0,1,0" UpDirection="0,0,1" FieldOfView="60"/>
                        </Viewport3D.Camera>
                        <ModelVisual3D>
                            <ModelVisual3D.Content>
                                <DirectionalLight Color="White" Direction="-1,-1,-3"/>
                            </ModelVisual3D.Content>
                        </ModelVisual3D>
                        <ModelVisual3D>
                            <ModelVisual3D.Content>
                                <AmbientLight Color="#404040"/>
                            </ModelVisual3D.Content>
                        </ModelVisual3D>
                        <ModelVisual3D>
                            <ModelVisual3D.Content>
                                <Model3DGroup>
                                    <!-- Bottle cap body. Mesh is generated in code so the side can be ribbed. -->
                                    <GeometryModel3D x:Name="DeviceBodyModel">
                                        <GeometryModel3D.Material>
                                            <DiffuseMaterial Brush="#AEB7C2"/>
                                        </GeometryModel3D.Material>
                                    </GeometryModel3D>

                                    <!-- +X axis, red -->
                                    <GeometryModel3D>
                                        <GeometryModel3D.Geometry>
                                            <MeshGeometry3D
                                                Positions="0,-0.035,-0.035 1.6,-0.035,-0.035 1.6,0.035,-0.035 0,0.035,-0.035 0,-0.035,0.035 1.6,-0.035,0.035 1.6,0.035,0.035 0,0.035,0.035"
                                                TriangleIndices="0,1,2 2,3,0 1,5,6 6,2,1 5,4,7 7,6,5 4,0,3 3,7,4 3,2,6 6,7,3 4,5,1 1,0,4"/>
                                        </GeometryModel3D.Geometry>
                                        <GeometryModel3D.Material>
                                            <DiffuseMaterial Brush="#E53935"/>
                                        </GeometryModel3D.Material>
                                    </GeometryModel3D>

                                    <!-- +Y axis, green -->
                                    <GeometryModel3D>
                                        <GeometryModel3D.Geometry>
                                            <MeshGeometry3D
                                                Positions="-0.035,0,-0.035 0.035,0,-0.035 0.035,1.25,-0.035 -0.035,1.25,-0.035 -0.035,0,0.035 0.035,0,0.035 0.035,1.25,0.035 -0.035,1.25,0.035"
                                                TriangleIndices="0,1,2 2,3,0 1,5,6 6,2,1 5,4,7 7,6,5 4,0,3 3,7,4 3,2,6 6,7,3 4,5,1 1,0,4"/>
                                        </GeometryModel3D.Geometry>
                                        <GeometryModel3D.Material>
                                            <DiffuseMaterial Brush="#43A047"/>
                                        </GeometryModel3D.Material>
                                    </GeometryModel3D>

                                    <!-- +Z axis, blue -->
                                    <GeometryModel3D>
                                        <GeometryModel3D.Geometry>
                                            <MeshGeometry3D
                                                Positions="-0.035,-0.035,0 0.035,-0.035,0 0.035,0.035,0 -0.035,0.035,0 -0.035,-0.035,1.6 0.035,-0.035,1.6 0.035,0.035,1.6 -0.035,0.035,1.6"
                                                TriangleIndices="0,1,2 2,3,0 1,5,6 6,2,1 5,4,7 7,6,5 4,0,3 3,7,4 3,2,6 6,7,3 4,5,1 1,0,4"/>
                                        </GeometryModel3D.Geometry>
                                        <GeometryModel3D.Material>
                                            <DiffuseMaterial Brush="#1E88E5"/>
                                        </GeometryModel3D.Material>
                                    </GeometryModel3D>
                                </Model3DGroup>
                            </ModelVisual3D.Content>
                            <ModelVisual3D.Transform>
                                <MatrixTransform3D x:Name="ModelMatrixTransform"/>
                            </ModelVisual3D.Transform>
                        </ModelVisual3D>
                    </Viewport3D>
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8" Background="#DDFFFFFF" BorderBrush="#CCCCCC" BorderThickness="1" Padding="8">
                        <StackPanel>
                            <TextBlock Text="Osie modelu" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="+X czerwony" Foreground="#E53935" FontWeight="SemiBold"/>
                            <TextBlock Text="+Y zielony" Foreground="#43A047" FontWeight="SemiBold"/>
                            <TextBlock Text="+Z niebieski" Foreground="#1E88E5" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Chart -->
            <Border Grid.Row="1" Margin="10" BorderBrush="LightGray" BorderThickness="1">
                <lvc:CartesianChart Series="{Binding GyroSeries}" />
            </Border>
        </Grid>
    </Grid>
</Window>
